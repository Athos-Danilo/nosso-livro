{
  "name": "servico-notificacao",
  "version": "1.0.0",
  "description": "Microsserviço de Notificações — Plataforma Nosso Livro",
  "main": "dist/servidor.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/servidor.ts",
    "build": "tsc",
    "start": "node dist/servidor.js",
    "test": "jest --verbose",
    "test:email": "jest --testPathPattern=ethereal --verbose",
    "test:pipeline": "jest --testPathPattern=processador --verbose",
    "prisma:migrar": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "prisma:gerar": "npx prisma generate"
  },
  "keywords": [
    "microsserviço",
    "notificação",
    "email",
    "nosso-livro"
  ],
  "author": "Marcus Vinícius",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "amqplib": "^2.0.1",
    "axios": "^1.18.1",
    "axios-retry": "^4.5.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "jest": "^30.4.2",
    "prisma": "^7.8.0",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
